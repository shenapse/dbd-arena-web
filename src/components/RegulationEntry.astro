---
// One regulation card, authored directly in markdown. The writer supplies all
// four props per instance — this component owns no data discovery or grouping.
import StatusBadge from './StatusBadge.astro';

interface Props {
  name: string;
  href?: string;
  status: 'active' | 'upcoming' | 'archived';
  description?: string;
}
const { name, href, status, description } = Astro.props;
---

<article class={`regulation-card${status !== 'active' ? ' regulation-card--muted' : ''}`}>
  <div class="regulation-card__header">
    <StatusBadge status={status} />
    <h3>{href ? <a href={href}>{name}</a> : name}</h3>
  </div>
  {description && <p class="regulation-card__summary">{description}</p>}
</article>
