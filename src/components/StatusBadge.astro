---
// Status is conveyed with TEXT and a glyph, never color alone — survives color-blindness and grayscale.
// Labels/tooltips are localized via Starlight's i18n (src/content/i18n/*.json); the
// glyph is locale-independent.
interface Props {
  status: "active" | "upcoming" | "archived";
}
const { status } = Astro.props;
const t = Astro.locals.t;

const GLYPHS = {
  active: "●",
  upcoming: "◓",
  archived: "✕",
} as const;

const TEXT_KEYS = {
  active: 'status.active',
  upcoming: 'status.upcoming',
  archived: 'status.archived',
} as const;

const TITLE_KEYS = {
  active: 'status.active.title',
  upcoming: 'status.upcoming.title',
  archived: 'status.archived.title',
} as const;

const glyph = GLYPHS[status];
const text = t(TEXT_KEYS[status]);
const title = t(TITLE_KEYS[status]);
---

<span class={`status-badge status-badge--${status}`} title={title}>
  <span aria-hidden="true">{glyph}</span>
  {text}
</span>
