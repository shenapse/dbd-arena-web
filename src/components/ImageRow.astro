---
// Reusable horizontal row of captioned images (offerings, items, add-ons, …).
// `src` values are root-absolute paths under public/, e.g.
// /images/offerings/Cut-Coin.webp
interface ImageItem {
  src: string;
  label?: string;   // caption under the image
  alt?: string;     // defaults to label
}
interface Props {
  images: ImageItem[];
  label?: string;   // optional small heading above the row (e.g. "Killer")
  size?: number;    // max image width in px (default 112)
}
const { images, label, size = 112 } = Astro.props;
---

<div class="image-row-group">
  {label && <p class="image-row__heading">{label}</p>}
  <div class="image-row" style={`--image-row-size: ${size}px`}>
    {images.map((img) => (
      <figure class="image-row__item">
        <img src={img.src} alt={img.alt ?? img.label ?? ''} loading="lazy" />
        {img.label && <figcaption>{img.label}</figcaption>}
      </figure>
    ))}
  </div>
</div>

<style>
  .image-row-group {
    margin: 0.75rem 0 1.25rem;
  }
  .image-row__heading {
    margin: 0 0 0.4rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }
  .image-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .image-row__item {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: var(--image-row-size);
  }
  .image-row__item img {
    width: 100%;
    height: auto;
    border-radius: 0.375rem;
  }
  .image-row__item figcaption {
    margin-top: 0.4rem;
    font-size: 0.85rem;
    line-height: 1.2;
    text-align: center;
    color: var(--sl-color-gray-2);
  }
</style>
